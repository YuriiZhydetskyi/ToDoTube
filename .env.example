# Copy this file to `.env` and fill in your TickTick OAuth credentials.
#
# Register a TickTick developer app at https://developer.ticktick.com/manage
# and set its OAuth redirect URL to exactly:
#   https://ticktick.com/todotube-oauth-callback
# (one URL for all platforms — see README → "TickTick OAuth setup").
#
# IMPORTANT: TickTick does not appear to support PKCE. The client secret
# ships inside the extension bundle and is therefore a PUBLIC value — it
# is not a real secret in the cryptographic sense. Do not treat it as one.
WXT_TT_CLIENT_ID=
WXT_TT_CLIENT_SECRET=

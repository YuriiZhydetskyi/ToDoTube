{
  "name": "todotube",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "description": "Replace YouTube recommendations with your to-do list.",
  "license": "MIT",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:firefox-android": "wxt build -b firefox && tsx scripts/run-android.ts",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip && wxt zip -b firefox",
    "compile": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "fixtures:capture": "tsx scripts/capture-fixtures.ts",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "postinstall": "wxt prepare",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.5",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.0.5",
    "wxt": "^0.20.0"
  }
}

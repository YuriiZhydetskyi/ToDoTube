{
  "name": "todotube",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Replace YouTube recommendations with your to-do list.",
  "license": "MIT",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip && wxt zip -b firefox",
    "compile": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5",
    "wxt": "^0.20.0"
  }
}

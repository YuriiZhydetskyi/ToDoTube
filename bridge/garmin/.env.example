# Copy to .env and fill in. Loaded via `node --env-file=.env` (Node 20+).
# These credentials NEVER leave this machine — the ToDoTube extension only
# talks to the local /today endpoint, never to Garmin directly.

GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-garmin-password

# Optional overrides (defaults shown):
# PORT=8930
# CACHE_MS=60000
